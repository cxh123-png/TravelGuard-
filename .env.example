# APP_NAME sets the display name used by logs, docs, and health checks.
APP_NAME=TravelGuard AI
# APP_ENV marks the runtime environment, such as local, test, staging, or production.
APP_ENV=local
# DEBUG enables developer-friendly behavior only in local development.
DEBUG=true
# API_PREFIX keeps versioned business APIs under one stable path.
API_PREFIX=/api/v1

# DATABASE_URL points SQLAlchemy and Alembic to PostgreSQL; replace host/port with your VM database address.
DATABASE_URL=postgresql+asyncpg://travelguard_user:123456@192.168.88.100:5432/travelguard
# DATABASE_ECHO controls whether SQLAlchemy prints SQL statements during local debugging.
DATABASE_ECHO=false

# JWT_SECRET_KEY is a development-only secret with enough length for HS256; never reuse it in production.
JWT_SECRET_KEY=change-me-in-local-env-with-at-least-32-bytes
# JWT_ALGORITHM defines the signing algorithm used by the authentication skeleton.
JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES defines the default lifetime for access tokens.
ACCESS_TOKEN_EXPIRE_MINUTES=60

# REDIS_URL points background jobs and cache clients to Redis.
REDIS_URL=redis://192.168.88.100:6379/0
# MILVUS_HOST points policy RAG components to Milvus.
MILVUS_HOST=192.168.88.100
# MILVUS_PORT points policy RAG components to Milvus.
MILVUS_PORT=19530
# MINIO_ENDPOINT points document and invoice storage clients to MinIO.
MINIO_ENDPOINT=192.168.88.100:9000
# MINIO_ACCESS_KEY stores the local MinIO access key.
MINIO_ACCESS_KEY=travelguard_minio
# MINIO_SECRET_KEY stores the local MinIO secret key.
MINIO_SECRET_KEY=12345678
